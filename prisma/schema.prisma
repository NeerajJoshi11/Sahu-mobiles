generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String           @id @default(cuid())
  name          String
  price         Float
  mrp           Float?
  description   String
  image         String
  screen        String
  processor     String
  ram           String           // Base RAM
  storage       String           // Base Storage
  category      String           @default("Smartphone")
  stock         Int              @default(10)
  modelId       String?          // To group different colors of the same model
  colorName     String?          // e.g., "Cosmic Grey"
  colorCode     String?          // e.g., "#808080"
  hasVariants   Boolean          @default(false)
  variants      ProductVariant[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  orderItems    OrderItem[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  ram       String
  storage   String
  colorName String?
  colorCode String?
  image     String? // New field for color-specific images
  price     Float
  mrp       Float?
  stock     Int     @default(10)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  customerName  String
  customerEmail String
  customerPhone String
  address       String
  pincode       String
  total         Float
  status        String      @default("PENDING")
  paymentMethod String      @default("ONLINE") // ONLINE, COD, WHATSAPP
  paymentStatus String      @default("PENDING") // PENDING, COMPLETED, COD
  deliveryMethod String     @default("STANDARD")
  fulfillmentProvider String @default("SAHU_LOCAL")
  deliveryBoyName String?
  assignedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  price           Float
  selectedColor   String?
  selectedVariant String? // E.g., "8GB / 128GB"
  product         Product @relation(fields: [productId], references: [id])
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String // We'll store comma-separated pincodes or JSON
}

model DeliveryBoy {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  status    String   @default("AVAILABLE") // AVAILABLE, BUSY, OFFLINE
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("PERCENTAGE") // PERCENTAGE or FLAT
  value       Float
  minAmount   Float    @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
